<div id="loginModal" class="modal">

  <div class="modal-content">

    <span class="close-modal">&times;</span>

    <div class="modal-logo">TrailTales</div>

    <h2>Making a list?</h2>
    <p>Log in to add your saves to a trip you can edit or share.</p>

    <button class="modal-btn google-btn">
        <img src="/images/google.png" alt="google">
        Continue with Google
    </button>

    <a href="/login" class="modal-btn email-btn">
        <img src="/images/email.png" alt="email">
        Continue with Email
    </a>

  </div>

</div>-->

<!-- LOGIN MODAL -->
<div id="loginModal" class="modal">

<div class="modal-content">

<span class="close-modal">&times;</span>

<div class="modal-logo">TrailTales</div>

<!-- ================= OPTIONS ================= -->

<div id="authOptions">

<h2>Making a list?</h2>
<p>Log in to add your saves to a trip you can edit or share.</p>

<button class="modal-btn google-btn">
<img src="/images/google.png">
Continue with Google
</button>

<button id="openRegister" class="modal-btn email-btn">
<img src="/images/email.png">
Continue with Email
</button>

</div>


<!-- ================= REGISTER ================= -->

<div id="registerForm" class="hidden">

<h2>Join TrailTales</h2>

<form action="/api/register" method="POST">

<div class="form-row">
<input type="text" name="firstName" placeholder="First Name" required>
<input type="text" name="lastName" placeholder="Last Name" required>
</div>

<input type="email" name="email" placeholder="Email address" required>

<input type="password" name="password" placeholder="Create a password" required>

<button type="submit" class="modal-btn email-btn">
Join
</button>

</form>

<p class="switch-auth">
Already a member?
<a href="#" id="switchLogin">Log in</a>
</p>

</div>


<!-- ================= LOGIN ================= -->

<div id="loginForm" class="hidden">

<h2>Welcome back</h2>

<form action="/api/login" method="POST">

<input type="email" name="email" placeholder="Email address" required>

<input type="password" name="password" placeholder="Password" required>

<button type="submit" class="modal-btn email-btn">
Sign In
</button>

</form>

<p class="switch-auth">
Not a member?
<a href="#" id="switchRegister">Join</a>
</p>

</div>

</div>
</div>


<!-- SIDE PANEL -->
<div id="sidePanel" class="side-panel">
  <div class="side-header">
    <span>Trip Created</span>
    <button id="closePanel">X</button>
  </div>
  <div id="savedItem"></div>
</div>


<script src="/js/navbar.js"></script>
<script src="/js/saveFeature.js"></script>

</body>
</html>